COMPOSE_PROJECT_NAME=ghostfolio
TZ=UTC

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300&sslmode=prefer
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# AGENT ORCHESTRATION (US-008)
ENABLE_FEATURE_AGENT_LANGGRAPH=false
ENABLE_FEATURE_AGENT_CHAT_DEMO_MODE=false
ANTHROPIC_API_KEY=<INSERT_ANTHROPIC_API_KEY>
AGENT_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AGENT_MODEL_TIMEOUT_MS=12000
AGENT_MAX_GRAPH_STEPS=4
AGENT_MARKET_DISCREPANCY_THRESHOLD_PCT=5
AGENT_BACKUP_SOURCE_TIMEOUT_MS=4000
AGENT_MEMORY_TTL_SECONDS=604800
AGENT_MEMORY_MAX_MESSAGES=40
AGENT_MEMORY_RECENT_MESSAGES=12
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=<INSERT_LANGSMITH_API_KEY>
LANGSMITH_PROJECT=ghostfolio-agent
LANGSMITH_WORKSPACE_ID=<INSERT_LANGSMITH_WORKSPACE_ID>

# AGENT EVAL (used by eval harness in apps/api/src/app/agent/evals/)
# This is the Ghostfolio security token for anonymous auth — NOT a JWT.
# Obtain from: Ghostfolio UI → Settings → Security Token
EVAL_ACCESS_TOKEN=<INSERT_EVAL_ACCESS_TOKEN>
